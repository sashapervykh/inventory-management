generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  user
  admin
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  first_name    String?
  last_name     String?
  provider      String
  provider_id   String
  type          UserType   @default(user)
  createdAt     DateTime   @default(now())
  last_login_at DateTime?

  @@unique([provider, provider_id])
 }